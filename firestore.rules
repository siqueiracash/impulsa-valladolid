rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper para verificar autenticación
    function isAuthenticated() {
      return request.auth != null;
    }

    // Validación de datos de auditoría
    function isValidAudit(data) {
      return data.businessName is string && data.businessName.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.createdAt != null;
    }

    match /audits/{auditId} {
      // Permitimos crear auditorías con validación estricta sin requerir auth obligatoria
      // para evitar problemas de configuración inicial de Anonymous Auth
      allow create: if isValidAudit(request.resource.data);
      
      // Bloqueamos lectura pública
      allow read: if false; 
    }
  }
}
